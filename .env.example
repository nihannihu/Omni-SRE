# ══════════════════════════════════════════════════════════
# Omni-SRE — Environment Variables
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════════

# ── Shared ──
MONGODB_URI=mongodb://localhost:27017/omni-sre
JWT_SECRET=change-me-to-a-256-bit-secret
JWT_REFRESH_SECRET=change-me-to-another-256-bit-secret

# ── Node.js Backend ──
NODE_ENV=development
PORT=3001
AI_ENGINE_URL=http://localhost:8000
GITHUB_WEBHOOK_SECRET=whsec_change_me

# ── Python AI Engine ──
GROQ_API_KEY=gsk_your_groq_api_key
GROQ_MODEL=qwen/qwen3-32b
GROQ_FALLBACK_MODEL=openai/gpt-oss-120b
HINDSIGHT_BASE_URL=http://localhost:8888
FASTAPI_PORT=8000

# ── Hindsight Server ──
HINDSIGHT_API_LLM_API_KEY=sk-your-openai-or-groq-key
