# ══════════════════════════════════════════════════════════
# Omni-SRE Frontend — .gitignore
# ══════════════════════════════════════════════════════════

# ── Dependencies ──
node_modules/

# ── Build Output ──
dist/
dist-ssr/

# ── Environment (secrets) ──
.env
.env.local
.env.*.local

# ── Logs ──
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Editor / IDE ──
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Playwright ──
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/

# ── Backend (lives on main branch — do NOT re-add here) ──
backend/
server/
ai-engine/
*.pyc
__pycache__/
venv/
